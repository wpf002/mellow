# --- Postgres (Railway) ---
DATABASE_URL="postgresql://user:pass@host:5432/mellow"

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET="generate-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# --- OAuth (optional for MVP) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- API ---
API_PORT="4000"
WEB_ORIGIN="http://localhost:3000"

# --- Web ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- AI (Claude via the Anthropic SDK; Phase 6) ---
# The whole AI layer is feature-flagged: it activates when ANTHROPIC_API_KEY is
# set (and AI_FEATURES isn't "false"). Without a key the app runs fully — the
# feed uses the pure v0 ranker and companion UI is hidden.
ANTHROPIC_API_KEY=""
AI_FEATURES="true"
AI_DEFAULT_MODEL="claude-opus-4-8"
