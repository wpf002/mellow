generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

// First-class visibility on user content. Enforced in the query layer, not the UI.
enum Visibility {
  PUBLIC
  FRIENDS
  GROUP
  PRIVATE
}

// Lifecycle of a prayer request. Answered prayers carry a testimonial.
enum PrayerStatus {
  OPEN
  ANSWERED
}

// Role within a prayer group.
enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

// Fellowship post reactions. Off-chain, no monetary value.
enum ReactionType {
  AMEN
  PRAISE
  PRAYING
  LOVE
}

// What kind of service earned reputation. Weights live in code (pure config),
// so history is stable if weights are re-tuned.
enum ReputationCategory {
  PRAYER_POSTED // shared a prayer request
  INTERCESSION // prayed for someone ("I prayed")
  ENCOURAGEMENT // commented on a prayer or post
  TESTIMONY // marked a prayer answered with a testimonial
  FELLOWSHIP // posted to the fellowship feed
  FAITHFULNESS // marked a daily prayer day
  COMMUNITY // created or joined a group / challenge
}

// ---------------------------------------------------------------------------
// Auth (Better Auth core) + Mellow profile fields
// Better Auth owns: name, email, emailVerified, image, timestamps, and the
// Session / Account / Verification models. Mellow adds the profile columns
// (handle, displayName, avatarUrl, bio, timezone), set via our own /me routes.
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String // Better Auth core display name (set at sign-up)
  image         String? // Better Auth core avatar (unused by product; see avatarUrl)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // --- Mellow profile ---
  handle      String? @unique // @username, set once during onboarding
  displayName String?
  avatarUrl   String?
  bio         String?
  timezone    String  @default("UTC") // needed for streak math (Phase 3)

  // --- Auth relations ---
  sessions Session[]
  accounts Account[]

  // --- Social graph ---
  following Follow[] @relation("follower") // rows where this user is the follower
  followers Follow[] @relation("following") // rows where this user is followed

  // --- Prayer Social (Phase 2) ---
  prayers      Prayer[]
  prayerLogs   PrayerLog[]
  comments     Comment[]
  testimonials Testimonial[]

  // --- Groups + Prayer Life (Phase 3) ---
  ownedGroups      PrayerGroup[]             @relation("groupOwner")
  groupMemberships GroupMember[]
  prayerDayMarks   PrayerDayMark[]
  challenges       ChallengeParticipation[]

  // --- Fellowship Feed + Messaging (Phase 4) ---
  posts               Post[]
  postReactions       PostReaction[]
  postComments        PostComment[]
  conversationMembers ConversationMember[]
  messages            Message[]

  // --- Reputation & Achievements (Phase 5, off-chain) ---
  reputationEvents ReputationEvent[]
  achievements     UserAchievement[]

  @@index([handle])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ---------------------------------------------------------------------------
// Social graph
// ---------------------------------------------------------------------------

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

// ---------------------------------------------------------------------------
// Prayer Social (Phase 2)
//
// Prayer is the core content entity. Intercession ("I prayed") is recorded as
// append-only PrayerLog events — never mutated or deleted — so they can feed
// streaks and reputation later. Derived counts (uniquePrayed / totalPrayed) are
// computed from those events in the query layer, never stored on Prayer.
// ---------------------------------------------------------------------------

model Prayer {
  id         String       @id @default(cuid())
  authorId   String
  author     User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title      String? // optional short heading
  body       String
  visibility Visibility   @default(PUBLIC)
  status     PrayerStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  answeredAt DateTime? // set when status flips to ANSWERED

  // Set when the prayer is posted into a group (visibility = GROUP).
  groupId String?
  group   PrayerGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  logs        PrayerLog[]
  comments    Comment[]
  testimonial Testimonial? // one testimonial per answered prayer

  @@index([authorId])
  // Wall + profile listing order (newest first) and cursor pagination.
  @@index([createdAt, id])
  @@index([visibility, createdAt])
  @@index([groupId, createdAt])
}

// Append-only intercession event. A user may pray for the same request more
// than once (each press is an event). uniquePrayed = distinct userId.
model PrayerLog {
  id        String   @id @default(cuid())
  prayerId  String
  prayer    Prayer   @relation(fields: [prayerId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([prayerId])
  @@index([prayerId, userId])
  @@index([userId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  prayerId  String
  prayer    Prayer   @relation(fields: [prayerId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([prayerId, createdAt])
}

// The answered-prayer testimonial. Exactly one per prayer (created by the author
// when marking the prayer answered).
model Testimonial {
  id        String   @id @default(cuid())
  prayerId  String   @unique
  prayer    Prayer   @relation(fields: [prayerId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Group Prayer + Prayer Life (Phase 3) — completes the MVP.
//
// Prayer streaks are derived, never stored: PrayerDayMark records one row per
// local day a user prayed (idempotent per day), and the streak/longest/challenge
// progress are computed from those events in the user's timezone. Challenge
// progress reuses the same PrayerDayMark events.
// ---------------------------------------------------------------------------

model PrayerGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation("groupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members GroupMember[]
  prayers Prayer[]

  @@index([createdAt, id])
}

model GroupMember {
  groupId  String
  group    PrayerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     GroupRole   @default(MEMBER)
  joinedAt DateTime    @default(now())

  @@id([groupId, userId])
  @@index([userId])
}

// Append-only prayer-day event feeding streaks + challenge progress. One row per
// user per local (timezone-aware) calendar day. `date` is that local day at UTC
// midnight; adjacency is compared by calendar-day label, not wall-clock instant.
model PrayerDayMark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String?
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  createdAt   DateTime @default(now())

  participants ChallengeParticipation[]

  @@index([startDate])
}

model ChallengeParticipation {
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@id([challengeId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Fellowship Feed + Messaging (Phase 4)
//
// Post is the fellowship-pillar content entity (distinct from Prayer). The feed
// ("Agape Algorithm" v0) is a pure, swappable ranking over visible posts —
// chronological with follow-graph affinity; the AI re-rank arrives in Phase 6.
// Reaction/comment counts and message unread counts are derived, never stored.
// ---------------------------------------------------------------------------

model Post {
  id         String     @id @default(cuid())
  authorId   String
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body       String
  visibility Visibility @default(PUBLIC)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  reactions PostReaction[]
  comments  PostComment[]

  @@index([authorId, createdAt])
  @@index([createdAt, id])
}

model PostReaction {
  postId    String
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType
  createdAt DateTime     @default(now())

  // One reaction per user per post (changing type replaces it).
  @@id([postId, userId])
  @@index([postId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

// A conversation between two or more members. 1:1 DMs are the MVP; the schema
// already supports groups.
model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // bumped on each new message for list ordering

  members  ConversationMember[]
  messages Message[]

  @@index([updatedAt])
}

model ConversationMember {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Read cursor: unread = messages after this from other members. Derived count.
  lastReadAt     DateTime     @default(now())
  joinedAt       DateTime     @default(now())

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ---------------------------------------------------------------------------
// Reputation & Achievements (Phase 5) — OFF-CHAIN ONLY.
//
// Reputation points have NO monetary value (tokenomics deferred behind legal
// review; the future Eternal Profile web3 layer mirrors this later).
// ReputationEvent is append-only — never mutate or delete history. Scores are
// a derived weighted sum by category (weights live in code); the badge engine
// is a pure function over event tallies. UserAchievement rows record awards
// idempotently (unique per user+achievement).
// ---------------------------------------------------------------------------

model ReputationEvent {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  ReputationCategory
  // What earned it (prayer id, post id, group id…) — for audit/dedupe, not joins.
  refId     String?
  createdAt DateTime           @default(now())

  @@index([userId, category])
  @@index([userId, createdAt])
}

// Achievement catalog row. The source of truth for definitions (code, title,
// criteria) lives in the pure badge engine; rows are upserted from it so
// awards have a stable FK target.
model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. "FIRST_PRAYER", "INTERCESSOR_10"
  title       String
  description String
  createdAt   DateTime @default(now())

  awards UserAchievement[]
}

model UserAchievement {
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  awardedAt     DateTime    @default(now())

  @@id([userId, achievementId])
  @@index([userId])
}
