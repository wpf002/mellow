generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

// First-class visibility on user content. Enforced in the query layer, not the UI.
enum Visibility {
  PUBLIC
  FRIENDS
  GROUP
  PRIVATE
}

// Lifecycle of a prayer request. Answered prayers carry a testimonial.
enum PrayerStatus {
  OPEN
  ANSWERED
}

// ---------------------------------------------------------------------------
// Auth (Better Auth core) + Mellow profile fields
// Better Auth owns: name, email, emailVerified, image, timestamps, and the
// Session / Account / Verification models. Mellow adds the profile columns
// (handle, displayName, avatarUrl, bio, timezone), set via our own /me routes.
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String // Better Auth core display name (set at sign-up)
  image         String? // Better Auth core avatar (unused by product; see avatarUrl)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // --- Mellow profile ---
  handle      String? @unique // @username, set once during onboarding
  displayName String?
  avatarUrl   String?
  bio         String?
  timezone    String  @default("UTC") // needed for streak math (Phase 3)

  // --- Auth relations ---
  sessions Session[]
  accounts Account[]

  // --- Social graph ---
  following Follow[] @relation("follower") // rows where this user is the follower
  followers Follow[] @relation("following") // rows where this user is followed

  // --- Prayer Social (Phase 2) ---
  prayers      Prayer[]
  prayerLogs   PrayerLog[]
  comments     Comment[]
  testimonials Testimonial[]

  @@index([handle])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ---------------------------------------------------------------------------
// Social graph
// ---------------------------------------------------------------------------

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

// ---------------------------------------------------------------------------
// Prayer Social (Phase 2)
//
// Prayer is the core content entity. Intercession ("I prayed") is recorded as
// append-only PrayerLog events — never mutated or deleted — so they can feed
// streaks and reputation later. Derived counts (uniquePrayed / totalPrayed) are
// computed from those events in the query layer, never stored on Prayer.
// ---------------------------------------------------------------------------

model Prayer {
  id         String       @id @default(cuid())
  authorId   String
  author     User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title      String? // optional short heading
  body       String
  visibility Visibility   @default(PUBLIC)
  status     PrayerStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  answeredAt DateTime? // set when status flips to ANSWERED

  logs        PrayerLog[]
  comments    Comment[]
  testimonial Testimonial? // one testimonial per answered prayer

  @@index([authorId])
  // Wall + profile listing order (newest first) and cursor pagination.
  @@index([createdAt, id])
  @@index([visibility, createdAt])
}

// Append-only intercession event. A user may pray for the same request more
// than once (each press is an event). uniquePrayed = distinct userId.
model PrayerLog {
  id        String   @id @default(cuid())
  prayerId  String
  prayer    Prayer   @relation(fields: [prayerId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([prayerId])
  @@index([prayerId, userId])
  @@index([userId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  prayerId  String
  prayer    Prayer   @relation(fields: [prayerId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([prayerId, createdAt])
}

// The answered-prayer testimonial. Exactly one per prayer (created by the author
// when marking the prayer answered).
model Testimonial {
  id        String   @id @default(cuid())
  prayerId  String   @unique
  prayer    Prayer   @relation(fields: [prayerId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}
